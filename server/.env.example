PORT=5001
CLIENT_ORIGIN=http://localhost:5173

# Local module — PostgreSQL (DIGIVETDB created in pgAdmin).
PGHOST=localhost
PGPORT=5432
PGDATABASE=DIGIVETDB
PGUSER=postgres
PGPASSWORD=your-postgres-password

# Online module — Supabase (planned). Settings → API in the Supabase dashboard.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

LOCAL_DATABASE_URL=

# Email (nodemailer) — used to send login credentials to newly registered pet owners.
# For Gmail: enable 2FA and create an App Password at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="DIGIVET - Lipa City Vet Office" <your-gmail@gmail.com>

# Full URL of the online portal shown in the credential email
ONLINE_APP_URL=http://localhost:5173